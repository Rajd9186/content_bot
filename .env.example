# Backend Settings
DATABASE_URL=sqlite+aiosqlite:///./verified_ai.db
SECRET_KEY=generate-a-secure-secret-key-for-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Provider: Groq (Recommended for speed)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Provider: Ollama (Local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_API_KEY=

# Search: Tavily
TAVILY_API_KEY=your_tavily_api_key_here

# Redis (optional — platform uses in-process event bus by default)
# Set REDIS_URL to enable Redis Pub/Sub for multi-instance scaling.
# REDIS_URL=redis://localhost:6379/0
