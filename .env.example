# ── Root Environment ──
# Copy to .env and fill in values.
# Hierarchy: .env.defaults < .env.{stage} < .env.local < process.env

# Application
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_content_intel
APP_DATABASE_POOL_SIZE=20
APP_DATABASE_MAX_OVERFLOW=10

# Redis
APP_REDIS_URL=redis://localhost:6379

# Logging
APP_LOG_LEVEL=DEBUG

# Auth
APP_JWT_SECRET=local-development-secret-not-for-production
APP_JWT_ALGORITHM=HS256
APP_JWT_EXPIRATION_MINUTES=15

# Rate Limiting
APP_RATE_LIMIT_TTL=60
APP_RATE_LIMIT_MAX=100

# OpenTelemetry
APP_OTLP_ENDPOINT=
APP_METRICS_PORT=9464

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
