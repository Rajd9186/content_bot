# Database (PostgreSQL preferred for production, SQLite for local dev)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/verified_ai
# DATABASE_URL=sqlite+aiosqlite:///./verified_ai.db

# Database pool settings (PostgreSQL)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# LLM API Keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Ollama for local LLM fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-super:cloud

# Search API
TAVILY_API_KEY=your_tavily_api_key

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
